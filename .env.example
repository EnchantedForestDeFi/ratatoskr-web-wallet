# Wallet API backend env vars
# Copy to backend/.env on the vps2 host. Owner-only readable (chmod 600).

# Server
PORT=3001
BIND_HOST=10.8.0.2          # WireGuard interface IP — keeps API off public internet
NODE_ENV=production

# RATR daemon RPC
# Mainnet: RPC_PORT=8282, RPC_USER=ratr_rpc, password from your mainnet ratatoskr.conf
# Testnet: RPC_PORT=19392, RPC_USER=ratrtestnet, password from your testnet.conf
RPC_HOST=127.0.0.1
RPC_PORT=19392
RPC_USER=ratrtestnet
RPC_PASS=your_rpc_password_here

# CORS (must match the frontend deploy URL exactly)
CORS_ORIGIN=https://wallet.ratatoskr.enchantedforestdefi.com

# eIquidus explorer (used for balance + history; UTXOs cross-checked against RPC gettxout)
EXPLORER_URL=http://127.0.0.1:3002
